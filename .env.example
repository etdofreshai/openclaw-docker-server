TZ=America/Chicago

# Pin a version if you do not want latest.
OPENCLAW_NPM_SPEC=openclaw@latest

# gateway | shell | custom
OPENCLAW_RUN_MODE=gateway

# Only used when OPENCLAW_RUN_MODE=custom
OPENCLAW_RUN_CMD=

# Optional one-time container setup command.
OPENCLAW_SETUP_CMD=

OPENCLAW_GATEWAY_BIND=0.0.0.0
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Optional runtime auth/config values
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
